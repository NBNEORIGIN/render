# Database — PostgreSQL in production, SQLite locally
DATABASE_URL=sqlite:///render.db
DB_PASSWORD=change-this

# Authentication — set a strong random token; leave empty to disable (local dev only)
APP_TOKEN=change-this-to-a-strong-random-token

# Image storage — path on host, bind-mounted into container at /images
# Set by deploy.sh to /opt/nbne/render/images
# Leave unset locally (defaults to static/images/)

# Public base URL — used in marketplace image links (must be publicly reachable)
PUBLIC_BASE_URL=https://render.nbnesigns.co.uk

# Anthropic API (for AI content generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for lifestyle image backgrounds)
OPENAI_API_KEY=sk-proj-...

# eBay API (for direct publishing)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_RU_NAME=your-ebay-ru-name
EBAY_ENVIRONMENT=PRODUCTION
EBAY_MERCHANT_LOCATION_KEY=default

# Flask
SECRET_KEY=change-this-to-random-string
