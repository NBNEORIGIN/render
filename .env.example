# Database — Cairn PostgreSQL on nbne1 (render_ prefixed tables in claw DB)
DATABASE_URL=postgresql://cairn:cairn_nbne_2026@192.168.1.228:5432/claw

# Image storage — path on host, bind-mounted into container at /images
# Set by deploy.sh to /opt/nbne/render/images
# Leave unset locally (defaults to static/images/)

# Public base URL — used in marketplace image links (must be publicly reachable)
PUBLIC_BASE_URL=https://render.nbnesigns.co.uk

# Anthropic API (for AI content generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for lifestyle image backgrounds)
OPENAI_API_KEY=sk-proj-...

# eBay API (for direct publishing)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_RU_NAME=your-ebay-ru-name
EBAY_ENVIRONMENT=PRODUCTION
EBAY_MERCHANT_LOCATION_KEY=default

# SMTP — for bug report emails (IONOS)
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=587
SMTP_USER=you@nbnesigns.com
SMTP_PASSWORD=your-email-password

# Etsy API (for direct publishing)
ETSY_API_KEY=your-etsy-keystring
ETSY_SHARED_SECRET=your-etsy-shared-secret
ETSY_SHOP_ID=11706740
ETSY_REDIRECT_URI=http://localhost:5000/etsy/oauth/callback

# Phloe shop integration (auto-publish to nbnesigns.co.uk/shop)
PHLOE_API_URL=https://app.nbnesigns.co.uk
PHLOE_TENANT_SLUG=mind-department
PHLOE_USERNAME=toby@nbnesigns.com
PHLOE_PASSWORD=your-phloe-password

# Flask
SECRET_KEY=change-this-to-random-string
